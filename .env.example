# ─── LLM Providers ───
# Primary: OpenAI (reasoning) + DeepSeek (Chinese NLP) + Gemini (scanning)
# Claude Code bridge: last-resort fallback (no API key needed — uses claude CLI)

OPENAI_API_KEY=sk-proj-your_key_here
DEEPSEEK_API_KEY=sk-your_key_here
GOOGLE_API_KEY=AIzaSy_your_key_here

# Anthropic API key (optional — only needed if using direct Anthropic provider)
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# Discord webhook URL for notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/xxxxx

# Discord Bot (A股分析师移动指挥中心)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=

# AKShare proxy patch token — routes push2.eastmoney.com through auth proxy
# Bypasses VPN/proxy blocks for EastMoney data (PE/PB/sector/turnover)
AKSHARE_PROXY_TOKEN=your_token_here

# Celery broker URL (override config/openclaw.yaml)
# CELERY_BROKER_URL=redis://redis:6379/0

# Surge proxy auto-remediation (proxy_health_pipeline)
SURGE_API_URL=http://host.docker.internal:6171
SURGE_API_PASSWORD=your_surge_api_key_here

# ─── QMT Broker (国信证券 via MiniQMT) ───
# Required for mode: qmt in config/broker.yaml
# QMT_ACCOUNT_ID=your_account_id
# QMT_MINI_QMT_PATH=/path/to/userdata_mini

# ─── Web UI access (HTTP Basic Auth) ───
# When BOTH are set, every page and API endpoint requires these credentials
# (/health stays public). Leave both empty to disable auth (default: open access).
# Recommended if you expose the dashboard beyond localhost.
WEB_USERNAME=
WEB_PASSWORD=
