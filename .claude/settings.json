{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(.venv/bin/ruff:*)",
      "Bash(ruff:*)",
      "Bash(.venv/bin/pytest:*)",
      "Bash(pytest:*)",
      "Bash(npx tsc:*)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(make logs)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ]
  }
}
